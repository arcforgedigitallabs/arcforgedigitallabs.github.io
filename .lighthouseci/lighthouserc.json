{
  "_comment": ".lighthouseci/lighthouserc.json",
  "ci": {
    "collect": {
      "urls": [
        "https://www.arcforgedigitallabs.com/",
        "https://www.arcforgedigitallabs.com/privacy",
        "https://www.arcforgedigitallabs.com/terms",
        "https://www.arcforgedigitallabs.com/about",
        "https://www.arcforgedigitallabs.com/press",
        "https://www.arcforgedigitallabs.com/support"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
